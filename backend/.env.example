# ---- Core ----
PROJECT_NAME="CourtBase BFMS"
ENVIRONMENT=development            # development | staging | production
API_V1_PREFIX=/api/v1
DEBUG=true

# ---- Security ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_EXPIRE_MINUTES=30

# ---- Database ----
# Local Postgres example (pure-Python pg8000 driver):
DATABASE_URL=postgresql+pg8000://postgres:postgres@localhost:5432/bfms
# Supabase example:
# DATABASE_URL=postgresql+pg8000://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# Prefer psycopg in production? install psycopg[binary] and use:
# DATABASE_URL=postgresql+psycopg://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ---- CORS (comma-separated origins) ----
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Rate limiting ----
RATE_LIMIT_DEFAULT=200/minute
RATE_LIMIT_AUTH=10/minute

# ---- Supabase Storage (player photos, club logos) ----
# Project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=
# service_role secret (Supabase dashboard -> Settings -> API). KEEP SECRET. Never commit.
SUPABASE_SERVICE_KEY=
STORAGE_PLAYER_PHOTOS_BUCKET=player-photos
STORAGE_CLUB_LOGOS_BUCKET=club-logos
STORAGE_MAX_IMAGE_MB=5

# ---- Bootstrap super admin (used by `python -m app.seed`) ----
FIRST_SUPERUSER_EMAIL=admin@courtbase.dev
FIRST_SUPERUSER_PASSWORD=ChangeMe123!
